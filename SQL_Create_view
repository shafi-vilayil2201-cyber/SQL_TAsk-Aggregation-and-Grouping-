CREATE VIEW View_BookAuthorDetails
AS
SELECT
    b.BookId,
    b.Title,
    b.Price,
    a.AuthorId,
    a.AuthorName,
    a.Country
FROM Books b
INNER JOIN Authors a
ON b.AuthorId = a.AuthorId;

