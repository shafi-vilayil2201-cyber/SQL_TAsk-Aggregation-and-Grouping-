--Create Authors Table
CREATE TABLE Authors (

    AuthorId INT PRIMARY KEY,

    AuthorName VARCHAR(255),

    Country VARCHAR(100)

);


CREATE TABLE Books (
    BookId INT PRIMARY KEY,
    Title VARCHAR(255),
    Price DECIMAL(10,2),
    AuthorId INT,

    FOREIGN KEY (AuthorId) REFERENCES Authors(AuthorId)
);


